---
// src/pages/contact.astro — La Boucle de La Boucle
import PageLayout from "../layouts/PageLayout.astro";

// TODO: ajouter les bonne adresses
// TODO: vérfier que les 3 boutons marchent et modifier le premier bouton
---

<PageLayout title="Contact — La Boucle de La Boucle">
  <main
    class="min-h-screen bg-dark flex flex-col items-center justify-center px-6 py-32 gap-4"
  >
    <!-- En-tête -->
    <div class="text-center flex flex-col gap-4">
      <h1 class="font-display--headings text-heading1 text-white text-shine">
        Contact
      </h1>
      <p class="text-body text-lightGrey/80 leading-relaxed">
        Une question, une proposition de collaboration,<br />
        une envie de nous voir jouer&nbsp;?
      </p>
      <p
        class="font-display--headings text-h4 text-primary uppercase tracking-widest -mb-6"
      >
        compagnie
      </p>
      <h2 class="font-display--bigHeading text-h3 text-white text-shine">
        La Boucle de la Boucle
      </h2>
    </div>

    <!-- Carte contacts -->
    <div
      class="w-full max-w-md flex flex-col overflow-hidden"
      style="background: rgba(255,255,255,0.03); border: 1px solid rgba(228,150,234,0.18); backdrop-filter: blur(8px);"
    >
    <button
        id="copy-adress-btn"
        data-adress="+33XXXXXXXXX"
        class="flex items-center gap-6 px-10 py-8 w-full text-left group transition-all duration-300 hover:bg-primary/5 cursor-pointer"
        aria-label="Copier l'adresse postale"
      >
        <div
          class="shrink-0 w-14 h-14 flex items-center justify-center text-primary transition-all duration-300 group-hover:text-glow"
          style="background: rgba(99,106,181,0.15); border: 1px solid rgba(99,106,181,0.3);"
        >
          <svg
            id="icon-phone"
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
            ></path>
          </svg>
          <svg
            id="icon-check-phone"
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            class="hidden"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4.5 12.75l6 6 9-13.5"></path>
          </svg>
        </div>

        <div class="flex flex-col gap-1">
          <span
            class="text-xs text-secondary uppercase tracking-widest font-medium"
          >
            Adresse
          </span>
          <span
            id="phone-label"
            class="text-h4 text-white font-light tracking-wide transition-colors duration-300 group-hover:text-primary"
          >
            15 rue de la boucle,</br> 30000 ville
          </span>
          <span
            id="phone-copied"
            class="text-xs text-primary tracking-wide hidden"
          >
            Copié dans le presse-papier !
          </span>
        </div>
      </button>

            <!-- Séparateur -->
      <div
        class="mx-10 h-px"
        aria-hidden="true"
        style="background: linear-gradient(to right, transparent, rgba(228,150,234,0.3), transparent);"
      >
      </div>

      <!-- Téléphone — copie dans le presse-papier -->
      <button
        id="copy-phone-btn"
        data-phone="+33XXXXXXXXX"
        class="flex items-center gap-6 px-10 py-8 w-full text-left group transition-all duration-300 hover:bg-primary/5 cursor-pointer"
        aria-label="Copier le numéro de téléphone"
      >
        <div
          class="shrink-0 w-14 h-14 flex items-center justify-center text-primary transition-all duration-300 group-hover:text-glow"
          style="background: rgba(99,106,181,0.15); border: 1px solid rgba(99,106,181,0.3);"
        >
          <svg
            id="icon-phone"
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
            ></path>
          </svg>
          <svg
            id="icon-check-phone"
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            class="hidden"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4.5 12.75l6 6 9-13.5"></path>
          </svg>
        </div>

        <div class="flex flex-col gap-1">
          <span
            class="text-xs text-secondary uppercase tracking-widest font-medium"
          >
            Téléphone
          </span>
          <span
            id="phone-label"
            class="text-h4 text-white font-light tracking-wide transition-colors duration-300 group-hover:text-primary"
          >
            +33 X XX XX XX XX
          </span>
          <span
            id="phone-copied"
            class="text-xs text-primary tracking-wide hidden"
          >
            Copié dans le presse-papier !
          </span>
        </div>
      </button>

      <!-- Séparateur -->
      <div
        class="mx-10 h-px"
        aria-hidden="true"
        style="background: linear-gradient(to right, transparent, rgba(228,150,234,0.3), transparent);"
      >
      </div>

      <!-- Email — copie dans le presse-papier -->
      <button
        id="copy-email-btn"
        data-email="contact@laboucle.fr"
        class="flex items-center gap-6 px-10 py-8 w-full text-left group transition-all duration-300 hover:bg-primary/5 cursor-pointer"
        aria-label="Copier l'adresse email"
      >
        <div
          class="shrink-0 w-14 h-14 flex items-center justify-center text-primary transition-all duration-300 group-hover:text-glow"
          style="background: rgba(99,106,181,0.15); border: 1px solid rgba(99,106,181,0.3);"
        >
          <!-- Icône enveloppe (état par défaut) -->
          <svg
            id="icon-email"
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
            ></path>
          </svg>
          <!-- Icône check (état copié) -->
          <svg
            id="icon-check"
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            class="hidden"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4.5 12.75l6 6 9-13.5"></path>
          </svg>
        </div>

        <div class="flex flex-col gap-1">
          <span
            class="text-xs text-secondary uppercase tracking-widest font-medium"
          >
            Email
          </span>
          <span
            id="email-label"
            class="text-h4 text-white font-light tracking-wide transition-colors duration-300 group-hover:text-primary"
          >
            contact@laboucle.fr
          </span>
          <span
            id="email-copied"
            class="text-xs text-primary tracking-wide hidden"
          >
            Copié dans le presse-papier !
          </span>
        </div>
      </button>
    </div>

    <!-- Note bas de page -->
    <p class="text-sm text-lightGrey/50 text-center leading-loose max-w-sm">
      Nous répondons généralement sous 48h ouvrées.<br />
      Pour les demandes de dossier de presse ou dossier technique, merci de le préciser en objet.
    </p>
  </main>
</PageLayout>

<script>
  const phoneBtn = document.getElementById("copy-phone-btn");
  const iconPhone = document.getElementById("icon-phone");
  const iconCheckPhone = document.getElementById("icon-check-phone");
  const phoneLabel = document.getElementById("phone-label");
  const phoneCopied = document.getElementById("phone-copied");

  phoneBtn?.addEventListener("click", async () => {
    const phone = phoneBtn.dataset.phone ?? "";
    try {
      await navigator.clipboard.writeText(phone);
      iconPhone?.classList.add("hidden");
      iconCheckPhone?.classList.remove("hidden");
      phoneLabel?.classList.add("hidden");
      phoneCopied?.classList.remove("hidden");
      setTimeout(() => {
        iconPhone?.classList.remove("hidden");
        iconCheckPhone?.classList.add("hidden");
        phoneLabel?.classList.remove("hidden");
        phoneCopied?.classList.add("hidden");
      }, 2000);
    } catch {
      // Fallback silencieux
    }
  });
</script>

<script>
  const btn = document.getElementById("copy-email-btn");
  const iconEmail = document.getElementById("icon-email");
  const iconCheck = document.getElementById("icon-check");
  const emailLabel = document.getElementById("email-label");
  const copiedMsg = document.getElementById("email-copied");

  btn?.addEventListener("click", async () => {
    const email = btn.dataset.email ?? "";
    try {
      await navigator.clipboard.writeText(email);
      // Feedback visuel
      iconEmail?.classList.add("hidden");
      iconCheck?.classList.remove("hidden");
      emailLabel?.classList.add("hidden");
      copiedMsg?.classList.remove("hidden");
      // Retour à l'état initial après 2s
      setTimeout(() => {
        iconEmail?.classList.remove("hidden");
        iconCheck?.classList.add("hidden");
        emailLabel?.classList.remove("hidden");
        copiedMsg?.classList.add("hidden");
      }, 2000);
    } catch {
      // Fallback si clipboard API indisponible
      emailLabel!.textContent = "contact@laboucle.fr";
    }
  });
</script>
