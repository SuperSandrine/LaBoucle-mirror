---
import PageLayout from "../../layouts/PageLayout.astro";
import imageCharlotte from "../../images/charlotte.webp";
import imageLeo from "../../images/leo.webp";
import imageAnnabelle from "../../images/annabelle.webp";
import imageZicky from "../../images/ziky.webp";

const membres = [
  {
    name: "Leo Sciarrino",
    role: "Co-directeur artistique",
    image: imageLeo,
    bio: "Auteur, clown et metteur en scène, il développe des formes populaires qui jouent avec le malaise, la poésie et l'absurde.",
  },
  {
    name: "Annabelle Vaillant",
    role: "Co-directrice artistique",
    image: imageAnnabelle,
    bio: "Comédienne et metteuse en scène, elle porte une écriture queer, frontale et sensible, ancrée dans le théâtre de rue.",
  },
  {
    name: "Ziky Versari",
    role: "Clown",
    image: imageZicky,
    bio: "Interprète tout-terrain, il navigue entre jeu burlesque, adresse directe au public et compositions physiques.",
  },
  {
    name: "Charlotte Weidmann",
    role: "Directrice de production",
    image: imageCharlotte,
    bio: "Production, diffusion et coordination: elle construit les conditions concrètes pour faire exister les projets en tournée.",
  },
];

const engagements = [
  {
    titre: "Queer & inclusif",
    texte:
      "Une scène ouverte aux identités multiples, aux récits minorés et aux formes de représentation non normées.",
    icone: "✦",
  },
  {
    titre: "Itinérant",
    texte:
      "Théâtres, places, jardins, salles des fêtes: nous adaptons les formes au lieu et aux publics.",
    icone: "◈",
  },
  {
    titre: "Piquant",
    texte:
      "Humour, friction, tendresse: des spectacles qui déplacent sans moraliser.",
    icone: "⬡",
  },
  {
    titre: "Ancré en Creuse",
    texte:
      "Depuis 2021, nous affirmons qu'une création exigeante peut naître et rayonner depuis les territoires ruraux.",
    icone: "◎",
  },
];

const repere = [
  {
    annee: "2021",
    titre: "Création de la compagnie",
    texte:
      "Naissance en Creuse autour d'une pratique de clown politique et populaire.",
  },
  {
    annee: "2023",
    titre: "Déploiement des stages",
    texte:
      "Mise en place d'ateliers et de stages pour amateurices et professionnel·les.",
  },
  {
    annee: "2025",
    titre: "Diffusion nationale",
    texte: "Tournées et présence sur des festivals de rue, dont Aurillac.",
  },
];
---

<PageLayout title="Compagnie - La Boucle de la Boucle">
  <main class="bg-dark overflow-hidden">
    <section class="relative pt-36 pb-20 px-6 md:px-14 lg:px-20">
      <div
        class="pointer-events-none absolute inset-0 opacity-50"
        aria-hidden="true"
      >
        <div
          class="absolute -top-24 -left-24 h-72 w-72 rounded-full bg-primary/20 blur-3xl"
        >
        </div>
        <div
          class="absolute top-1/3 -right-24 h-80 w-80 rounded-full bg-secondary/25 blur-3xl"
        >
        </div>
      </div>

      <div
        class="relative mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-12 items-start"
      >
        <div>
          <p
            class="text-primary font-display--sans uppercase tracking-[0.2em] text-sm"
          >
            Compagnie de clown et théâtre de rue
          </p>
          <h1
            class="mt-5 font-display--bigHeading text-white leading-[0.9] text-[clamp(3rem,8vw,7rem)] text-shine"
          >
            La Boucle
            <br />
            de La Boucle
          </h1>

          <div
            class="mt-7 flex flex-wrap gap-3 text-xs md:text-sm uppercase tracking-widest"
          >
            <span
              class="border border-primary/60 bg-primary/10 text-primary px-3 py-2"
              >Creuse</span
            >
            <span class="border border-white/20 text-white/80 px-3 py-2"
              >Créée en 2021</span
            >
            <span class="border border-secondary/50 text-secondary px-3 py-2"
              >Queer & tout-terrain</span
            >
          </div>

          <div
            class="mt-8 max-w-2xl space-y-5 text-white/80 leading-relaxed text-body"
          >
            <p>
              Nous créons des spectacles de clown contemporains, des formes de
              rue et des temps de transmission. Notre ligne: faire rire fort,
              ouvrir des brèches, et garder le lien direct avec les publics.
            </p>
            <p>
              La compagnie défend une pratique populaire et exigeante, qui
              circule entre festivals, petites communes et scènes
              conventionnées.
            </p>
          </div>

          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a
              href="/spectacles"
              class="border-2 border-primary text-primary font-display--headings px-8 py-4 text-h4 hover:bg-primary hover:text-dark transition"
            >
              Voir les spectacles
            </a>
            <a
              href="/stages"
              class="border-2 border-white/30 text-white font-display--headings px-8 py-4 text-h4 hover:border-white transition"
            >
              Voir les stages
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4 lg:mt-8">
          {
            [imageLeo, imageAnnabelle, imageZicky, imageCharlotte].map(
              (img, idx) => (
                <div
                  class={`overflow-hidden border border-white/15 ${idx === 0 ? "col-span-2 aspect-[16/10]" : "aspect-[4/5]"}`}
                >
                  <img
                    src={img.src}
                    alt="Membre de la compagnie"
                    class="h-full w-full object-cover object-top transition duration-500 hover:scale-105"
                  />
                </div>
              ),
            )
          }
        </div>
      </div>
    </section>

    <section class="px-6 md:px-14 lg:px-20 pb-20">
      <div
        class="mx-auto max-w-7xl grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 border border-white/10"
      >
        {
          engagements.map((item, index) => (
            <article
              class={`p-7 bg-black/20 hover:bg-white/5 transition ${index < engagements.length - 1 ? "border-b sm:border-b-0 sm:border-r border-white/10" : ""}`}
            >
              <p class="font-display--bigHeading text-primary text-3xl">
                {item.icone}
              </p>
              <h2 class="mt-3 font-display--headings text-h4 text-white uppercase">
                {item.titre}
              </h2>
              <p class="mt-3 text-white/70 text-sm leading-relaxed">
                {item.texte}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <section
      class="py-20 px-6 md:px-14 lg:px-20 bg-black/25 border-y border-white/10"
    >
      <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div>
          <p class="text-secondary uppercase tracking-[0.2em] text-xs">
            Repères
          </p>
          <h2
            class="mt-4 text-h2 text-white font-display--headings leading-tight text-shine"
          >
            D'ou vient la compagnie
          </h2>
        </div>

        <div class="lg:col-span-2 space-y-5 text-white/80 leading-relaxed">
          <p>
            La Boucle de la Boucle est née d'un besoin simple: proposer des
            formes artistiques fortes dans des territoires souvent éloignés des
            grands circuits culturels. Nous travaillons en proximité, dans des
            formats souples, avec une esthétique qui assume le décalage et la
            rencontre.
          </p>

          <div class="mt-8 space-y-4">
            {
              repere.map((item) => (
                <article class="grid grid-cols-[70px_1fr] gap-4 border-l-2 border-primary/50 pl-5 py-2">
                  <p class="text-primary font-display--headings text-h4">
                    {item.annee}
                  </p>
                  <div>
                    <h3 class="text-white font-display--headings text-h4">
                      {item.titre}
                    </h3>
                    <p class="text-white/70 text-sm mt-1">{item.texte}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-6 md:px-14 lg:px-20">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12 flex items-end justify-between gap-6 flex-wrap">
          <div>
            <p class="text-primary uppercase tracking-[0.2em] text-xs">
              Equipe
            </p>
            <h2
              class="mt-3 text-h2 text-white font-display--headings text-shine"
            >
              Les membres
            </h2>
          </div>
          <a
            href="/contact"
            class="text-secondary hover:text-primary transition font-display--headings text-h4"
          >
            Inviter la compagnie
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {
            membres.map((membre) => (
              <article class="group border border-white/12 bg-black/20 p-5 md:p-6 flex flex-col sm:flex-row gap-5 hover:bg-white/5 transition">
                <div class="w-full sm:w-40 shrink-0 aspect-[3/4] overflow-hidden border border-white/15">
                  <img
                    src={membre.image.src}
                    alt={`Photo de ${membre.name}`}
                    class="h-full w-full object-cover object-top grayscale group-hover:grayscale-0 transition duration-500"
                  />
                </div>
                <div>
                  <h3 class="font-display--headings text-h3 text-white leading-tight">
                    {membre.name}
                  </h3>
                  <p class="mt-1 text-primary uppercase tracking-widest text-xs">
                    {membre.role}
                  </p>
                  <p class="mt-4 text-white/70 text-sm leading-relaxed">
                    {membre.bio}
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      class="py-20 px-6 md:px-14 lg:px-20 bg-secondary/10 border-y border-secondary/30"
    >
      <div
        class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-10 items-center"
      >
        <div>
          <p class="text-secondary uppercase tracking-[0.2em] text-xs">
            Festival
          </p>
          <h2 class="mt-3 font-display--headings text-h2 text-white">
            Les Désinvoltes
          </h2>
          <p class="mt-5 text-white/80 leading-relaxed">
            Tous les deux ans, nous programmons un temps fort qui rassemble des
            artistes queers, des formes hybrides et des propositions de rue. Le
            festival affirme notre volonté de créer des espaces festifs,
            exigeants et accessibles.
          </p>
          <div
            class="mt-8 flex gap-3 flex-wrap text-xs uppercase tracking-wider"
          >
            <span
              class="border border-secondary/60 bg-secondary/20 px-3 py-2 text-white"
              >Clown</span
            >
            <span
              class="border border-secondary/60 bg-secondary/20 px-3 py-2 text-white"
              >Cabaret</span
            >
            <span
              class="border border-secondary/60 bg-secondary/20 px-3 py-2 text-white"
              >Performance</span
            >
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <img
            src="/images/spectacles/comment-devenir-riche/visuel.webp"
            alt="Visuel du spectacle Comment devenir riche"
            class="w-full h-44 md:h-52 object-cover border border-secondary/30"
          />
          <img
            src="/images/spectacles/la-lutte-finale/visuel.jpg"
            alt="Visuel du spectacle La lutte finale"
            class="w-full h-44 md:h-52 object-cover border border-secondary/30"
          />
          <img
            src="/images/spectacles/billets.webp"
            alt="Billetterie spectacle"
            class="col-span-2 h-40 md:h-48 w-full object-cover border border-secondary/30"
          />
        </div>
      </div>
    </section>

    <section class="py-24 px-6 text-center">
      <div class="max-w-3xl mx-auto">
        <h2
          class="font-display--bigHeading text-white leading-tight text-[clamp(2.3rem,6vw,5rem)] text-shine"
        >
          Une date a proposer ?
        </h2>
        <p class="mt-6 text-white/70 leading-relaxed">
          Programmation, résidence, intervention artistique, atelier:
          écrivez-nous. Nous adaptons les formats selon les lieux et les
          publics.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="border-2 border-primary text-primary font-display--headings px-10 py-4 text-h4 hover:bg-primary hover:text-dark transition"
          >
            Nous contacter
          </a>
          <a
            href="/spectacles"
            class="border-2 border-white/30 text-white font-display--headings px-10 py-4 text-h4 hover:border-white transition"
          >
            Voir le repertoire
          </a>
        </div>
      </div>
    </section>
  </main>
</PageLayout>
