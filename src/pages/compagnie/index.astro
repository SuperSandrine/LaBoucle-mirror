---
import PageLayout from "../../layouts/PageLayout.astro";
import { Image } from "astro:assets";
import imageCharlotte from "../../images/charlotte.webp";
import imageLeo from "../../images/leo.webp";
import imageAnnabelle from "../../images/annabelle.webp";
import imageZicky from "../../images/ziky.webp";

const membres = [
  {
    name: "Leo Sciarrino",
    role: "Co-directeur artistique",
    image: imageLeo,
    bio: `Leo est <strong class="text-white font-medium">clown, performeur drag/burlesque, metteur en scène</strong>. Il a travaillé à Paris dans le social jusqu'en 2018. En 2021, avec Annabelle Vaillant, il co-créé la compagnie <strong class="text-white font-medium">La Boucle de la Boucle</strong>, dont il est co-directeur artistique. Au sein de la compagnie, il joue, met en scène, et facilite des stages et ateliers. Il a également co-créé le <strong class="text-white font-medium">festival Les Désinvoltes</strong> avec Charlotte Weidmann.<br>En dehors de la compagnie, il milite au sein de l'association <strong class="text-white font-medium">LGBTQIA+ Creuse</strong>.`,
  },
  {
    name: "Annabelle Vaillant",
    role: "Co-directrice artistique",
    image: imageAnnabelle,
    bio: `Co-directrice de la compagnie, Annabelle est <strong class="text-white font-medium">clown, autrice et metteuse en scène</strong> (<em>Soyez Libres c’est un ordre</em>, <em>Le temps c’est de l’argent</em>, <em>Comment devenir riche</em>, <em>La lutte Finale</em>, ou encore <em>SPUNNK</em> avec Anna Gianferrari).<br>En dehors de la compagnie, elle écrit des <strong class="text-white font-medium">textes de non-fiction</strong> (publiés dans des revues telles que <em>Baragouine</em> ou <em>Woman Journal</em>).`,
  },
  {
    name: "Ziky Versari",
    role: "Clown",
    image: imageZicky,
    bio: `Ziky Versari est <strong class="text-white font-medium">clown-e et jongleureuse antipodiste</strong>. Iel a suivi une formation de cirque, à laquelle iel a ajouté le clown. Iel développe des univers artistiques en plaçant <strong class="text-white font-medium">le corps</strong> au centre de l’action : un corps malléable, hors norme et <strong class="text-white font-medium">queer</strong>. À travers le clown et la jonglerie, iel explore des comportements non normés, dans une démarche de <strong class="text-white font-medium">légitimation des existences marginales</strong>. Au sein de la compagnie la Boucle de la Boucle, iel est pédagogue d’ateliers clown, comédienx et metteureuse et scène pour <em>La Lutte Finale</em>, et en cours de création de son solo <em>Baignoire</em>.`,
  },
  {
    name: "Charlotte Weidmann",
    role: "Directrice de production",
    image: imageCharlotte,
    bio: `Charlotte travaille en <strong class="text-white font-medium">production / administration / coordination</strong> dans le <strong class="text-white font-medium">spectacle vivant</strong> depuis 13 ans, après des études à Sciences Po Paris.<br>Elle a créé avec Leo Sciarrino le <strong class="text-white font-medium">festival Les Désinvoltes</strong>, évènement <strong class="text-white font-medium">queer et pluridisciplinaire</strong> dont elle assure la coordination.<br>Elle est aussi directrice de production pour 2 autres compagnies, le <strong class="text-white font-medium">Blast Collective</strong> à Limoges et la <strong class="text-white font-medium">cie Yvonne III</strong> à Joigny`,
  },
];

