    <section class="py-20 px-6 md:px-14 lg:px-20">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12 flex items-end justify-between gap-6 flex-wrap">
          <div>
            <p class="text-primary uppercase tracking-[0.2em] text-xs">
              Equipe
            </p>
            <h2
              class="mt-3 text-h2 text-white font-display--headings text-shine"
            >
              Les membres
            </h2>
          </div>
          <a
            href="/contact"
            class="text-secondary hover:text-primary transition font-display--headings text-h4"
          >
            Inviter la compagnie
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {
            membres.map((membre, idx) => (
              <article class="group  bg-black/20 p-5 md:p-6 flex flex-col sm:flex-row gap-5 hover:bg-white/5 transition">
                <div class="w-full sm:w-40 shrink-0 aspect-3/4 overflow-hidden ">
                  <Image
                    src={membre.image}
                    alt={`${membre.name}, ${membre.role} — La Boucle de la Boucle`}
                    class={`h-full w-full object-cover object-top grayscale group-hover:grayscale-0 transition duration-500${idx === 0 ? " contrast-125" : ""}`}
                    loading="lazy"
                  />
                </div>
                <div>
                  <h3 class="font-display--headings text-h3 text-white leading-tight">
                    {membre.name}
                  </h3>
                  <p class="mt-1 text-primary uppercase tracking-widest text-xs">
                    {membre.role}
                  </p>
                  <p
                    class="mt-4 text-white/70 text-sm leading-relaxed"
                    set:html={membre.bio}
                  />
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      class="py-20 px-6 md:px-14 lg:px-20 bg-secondary/10 border-y border-secondary/30"
    >
      <div
        class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-10 items-center"
      >
        <div>
          <p class="text-secondary uppercase tracking-[0.2em] text-xs">
            Festival
          </p>
          <h2 class="mt-3 font-display--headings text-h2 text-white text-shine">
            Les Désinvoltes
          </h2>
          <p class="mt-5 text-white/80 leading-relaxed">
            Tous les deux ans, nous programmons un temps fort qui rassemble des
            artistes queers, des formes hybrides et des propositions de rue. Le
            festival affirme notre volonté de créer des espaces festifs,
            exigeants et accessibles.
          </p>
          <div class="mt-8 flex gap-3 flex-wrap">
            <span class="badge-outline">Clown</span>
            <span class="badge-outline">Cabaret</span>
            <span class="badge-outline">Performance</span>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <Image
            src="/images/galerie/festival/desinvoltes-1.webp"
            alt="rassemblement extérieur du festival Désinvoltes"
            width={600}
            height={400}
            class="w-full h-44 md:h-52 object-cover"
            loading="lazy"
          />
          <Image
            src="/images/galerie/festival/desinvoltes-2.webp"
            alt="soirée DJ du festival Désinvoltes"
            width={989}
            height={600}
            class="w-full h-44 md:h-52 object-cover"
            loading="lazy"
          />
          <Image
            src="/images/galerie/festival/desinvoltes.webp"
            alt="scène musicale du festival Désinvoltes"
            class="col-span-2 md:h-52 h-44 w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <section class="py-24 px-6 text-center">
      <div class="max-w-3xl mx-auto">
        <h2
          class="font-display--headings text-white leading-tight text-h2 text-shine"
        >
          Une date a proposer ?
        </h2>
        <p class="mt-6 text-white/70 leading-relaxed">
          Programmation, résidence, intervention artistique, atelier:
          écrivez-nous. Nous adaptons les formats selon les lieux et les
          publics.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="border-2 border-primary text-primary font-display--headings px-10 py-4 text-h4 hover:bg-primary hover:text-dark transition"
          >
            Nous contacter
          </a>
          <a
            href="/spectacles"
            class="border-2 border-white/30 text-white font-display--headings px-10 py-4 text-h4 hover:border-white transition"
          >
            Voir le repertoire
          </a>
        </div>
      </div>
    </section>
  </main>
</PageLayout>
