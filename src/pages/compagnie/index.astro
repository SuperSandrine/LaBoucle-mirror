              <p class="font-display--bigHeading text-primary text-3xl">
                {item.icone}
              </p>
              <h2 class="mt-3 font-display--headings text-h4 text-white uppercase tracking-wider">
                {item.titre}
              </h2>
              <p class="mt-3 text-white/70 text-body">
                {item.texte}
              </p>
            </article>
          ))
        }
      </div>
    </section> -->
