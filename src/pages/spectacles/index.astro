---
// TODO: utiliser les meme mises en pages que la page d'accueil
// TODO: créer un boutoon pour voir la fiche
import DatesArchives from "../../components/sections/DatesArchives.astro";
import PageLayout from "../../layouts/PageLayout.astro";
import { getCollection } from "astro:content";
import ShowCard from "../../components/ui/ShowCard.astro";
import { Image } from 'astro:assets';

const spectacles = await getCollection("spectacles");
const datesCollection = await getCollection("dates");

const findFirstDate = (slug: string) => {
  const datesForShow = datesCollection
    .filter((item) => item.data.evenement?.discriminant === "spectacle")
    .filter((item) => item.data.evenement?.value === slug)
    .map((item) => item.data.date)
    .sort((a, b) => a.getTime() - b.getTime());
  return datesForShow.length > 0 ? datesForShow[0] : undefined;
};

const sortedSpectacles = [...spectacles].sort((a, b) => {
  const dateA = findFirstDate(a.slug);
  const dateB = findFirstDate(b.slug);
  if (!dateA && !dateB)
    return a.data.title.localeCompare(b.data.title, "fr", {
      sensitivity: "base",
    });
  if (!dateA) return 1;
  if (!dateB) return -1;
  return dateA.getTime() - dateB.getTime();
});

const genres = Array.from(
  new Set(
    sortedSpectacles
      .map((item) => item.data.genreEtRegistre)
      .filter((genre): genre is string => Boolean(genre?.trim())),
  ),
);
---

<PageLayout
  title="Spectacles - La Boucle de la Boucle"
  description="Découvrez les spectacles de la compagnie La Boucle de la boucle : théâtre, clown, tout terrain. Disponibles pour festivals, tournées et représentations."
>
  <main class="bg-dark pt-36 pb-20 px-6">
    <section
      class="mx-auto max-w-7xl pb-10"
    >
      <h1
        class="font-display--headings text-white text-h2 md:text-heading1 leading-none text-shine"
      >
        Nos spectacles
      </h1>
      <!-- <p class="pt-6 max-w-3xl text-lightGrey text-bodyBig">
        Une vue rapide pour choisir un univers, comparer les formats et accéder
        à chaque fiche complète.
      </p> -->

      <div class="mt-8 flex flex-wrap items-center gap-3 text-sm md:text-base">
        <span class="badge-primary">
          {sortedSpectacles.length} spectacle{
            sortedSpectacles.length > 1 ? "s" : ""
          }
        </span>
        {
          genres
            .slice(0, 4)
            .map((genre) => (
              <span class="badge-outline">{genre}</span>
            ))
        }
      </div>
    </section>

    <section class="mx-auto py-10 max-w-7xl">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
        {
          sortedSpectacles.map((spectacle) => (
            <article class="group overflow-hidden bg-secondary/10  shadow-lg transition duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-primary/90">
              <a href={`/spectacles/${spectacle.slug}`} class="block">
                <div class="relative h-64 overflow-hidden bg-black">
                  <Image
                    src={spectacle.data.visuel}
                    alt={spectacle.data.title}
                    width={800}
                    height={600}
                    class={
                      `h-full w-full object-cover ${spectacle.slug === "prince-sse-pudeur" ? "object-[0%_25%]" : "object-center"} transition duration-300 group-hover:scale-120`
                    }
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
                  <span class="absolute left-4 top-4 badge-primary-solid">
                    {spectacle.data.genreEtRegistre}
                  </span>
                </div>

                <div class="p-6 flex flex-col">
                  <p class="font-display--sans text-body uppercase tracking-wider text-secondary">
                    Création {spectacle.data.creation}
                  </p>
                  <h2 class="pt-3 font-display--headings text-h3 text-white">
                    {spectacle.data.title}
                  </h2>

                  <p class="pt-3 text-white/70">{spectacle.data.synopsis}</p>

                  <div class="mt-5 flex flex-wrap gap-2">
                    <span class="badge-outline">{spectacle.data.duree}</span>
                    <span class="badge-outline">{spectacle.data.public}</span>
                  </div>

                  <span class="mt-5 w-fit btn-outline">
                    En savoir plus
                  </span>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </section>
    <DatesArchives filter="spectacle" />
  </main>
</PageLayout>
