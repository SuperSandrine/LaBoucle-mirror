---
import PageLayout from "../../layouts/PageLayout.astro";
import { getCollection } from "astro:content";

const spectacles = await getCollection("spectacles");

const sortedSpectacles = [...spectacles].sort((a, b) =>
  a.data.title.localeCompare(b.data.title, "fr", { sensitivity: "base" }),
);

const genres = Array.from(
  new Set(
    sortedSpectacles
      .map((item) => item.data.genreEtRegistre)
      .filter((genre): genre is string => Boolean(genre?.trim())),
  ),
);
---

<PageLayout title="Spectacles - La Boucle de la Boucle">
  <main class="bg-dark pt-36 pb-20 px-4 md:px-8">
    <section class="mx-auto max-w-7xl rounded-3xl border border-primary/20 bg-gradient-to-br from-dark via-secondary/30 to-dark p-8 md:p-12 shadow-2xl shadow-black/40">
      <p class="font-display--sans uppercase tracking-[0.2em] text-primary text-sm md:text-base">
        Répertoire vivant
      </p>
      <h1 class="mt-4 font-display--headings text-white text-h2 md:text-heading1 leading-none text-shine">
        Nos spectacles en cartes
      </h1>
      <p class="mt-6 max-w-3xl text-lightGrey text-bodyBig leading-relaxed">
        Une vue rapide pour choisir un univers, comparer les formats et accéder
        à chaque fiche complète.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3 text-sm md:text-base">
        <span class="rounded-full border border-primary/40 bg-primary/15 px-4 py-2 text-white">
          {sortedSpectacles.length} spectacle{sortedSpectacles.length > 1 ? "s" : ""}
        </span>
        {
          genres.slice(0, 4).map((genre) => (
            <span class="rounded-full border border-white/20 px-4 py-2 text-lightGrey">
              {genre}
            </span>
          ))
        }
      </div>
    </section>

    <section class="mx-auto mt-10 max-w-7xl">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
        {
          sortedSpectacles.map((spectacle) => (
            <article class="group overflow-hidden rounded-2xl border border-white/10 bg-lightGrey shadow-lg transition hover:-translate-y-1 hover:shadow-2xl hover:shadow-primary/20">
              <a href={`/spectacles/${spectacle.slug}`} class="block">
                <div class="relative h-64 overflow-hidden bg-black">
                  <img
                    src={spectacle.data.visuel}
                    alt={`Visuel du spectacle ${spectacle.data.title}`}
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
                  <span class="absolute left-4 top-4 rounded-full bg-primary px-3 py-1 text-xs font-bold uppercase tracking-wide text-black">
                    {spectacle.data.genreEtRegistre}
                  </span>
                </div>

                <div class="p-6">
                  <p class="font-display--sans text-sm uppercase tracking-widest text-secondary">
                    Création {spectacle.data.creation}
                  </p>
                  <h2 class="mt-3 font-display--headings text-h3 leading-tight text-dark">
                    {spectacle.data.title}
                  </h2>

                  <p class="mt-3 text-dark/80 line-clamp-3 min-h-[4.5rem]">
                    {spectacle.data.synopsis}
                  </p>

                  <div class="mt-5 flex flex-wrap gap-2 text-sm">
                    <span class="rounded-full border border-dark/20 px-3 py-1 text-dark">
                      {spectacle.data.duree}
                    </span>
                    <span class="rounded-full border border-dark/20 px-3 py-1 text-dark">
                      {spectacle.data.public}
                    </span>
                  </div>

                  <span class="mt-6 inline-flex items-center gap-2 font-display--headings text-h4 text-secondary transition group-hover:text-accentWarning">
                    Voir la fiche
                    <span aria-hidden="true">→</span>
                  </span>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</PageLayout>
