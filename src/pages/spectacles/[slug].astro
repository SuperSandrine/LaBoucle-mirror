---
import PageLayout from "../../layouts/PageLayout.astro";
import { Image } from 'astro:assets';

// Page de liste (ex: src/pages/repertoire.astro)
import { getCollection } from "astro:content";
const tousLesSpectacles = await getCollection("spectacles");

// Récupérer le slug depuis l'URL (ex: /spectacles/comment-devenir-riche → slug = "comment-devenir-riche")
const { slug } = Astro.params;
// Chercher le spectacle correspondant au slug
const spectacle = tousLesSpectacles.find((s) => s.slug === slug);
// Si aucun spectacle trouvé, afficher une erreur 404
if (!spectacle) {
  throw new Error(`Spectacle non trouvé pour le slug : ${slug}`);
}

const { Content } = await spectacle.render();

//console.log("SPECTACLE TROUVÉ : ", "RENDERED HTML : ", Content);
// {await spectacle.render().then((r) => r.body)}

//console.log("CEQUEJAI ICI: ", tousLesSpectacles);

// TODO: reduire espacement entre les lignes du tires, ajuster les couleurs du surtitre
---

<PageLayout
  title={`${spectacle.data.title} — La Boucle de la boucle`}
  description={spectacle.data.synopsis}
  ogImage={spectacle.data.visuel}
  ogType="article"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "name": spectacle.data.title,
    "description": spectacle.data.synopsis,
    "dateCreated": spectacle.data.creation,
    "genre": spectacle.data.genreEtRegistre ?? "Théâtre",
    "inLanguage": "fr",
    "author": {
      "@type": "PerformingGroup",
      "name": "La Boucle de la Boucle",
      "url": "https://laboucledelaboucle.fr"
    },
    "image": `https://laboucledelaboucle.fr${spectacle.data.visuel}`,
    "url": `https://laboucledelaboucle.fr/spectacles/${spectacle.slug}`
  })} />
  <main class="bg-dark pt-40 px-4 flex flex-col items-center">
    <div class="max-w-6xl w-full">
      <article
        class="flex flex-col md:flex-row shadow-xl overflow-hidden min-h-[500px] mb-16 bg-gradient-to-br from-dark via-secondary/30 to-dark shadow-2xl shadow-primary/50 md:-rotate-1"
      >
        <div class="md:w-1/2 relative min-h-[350px] md:min-h-full bg-dark">
          <Image
            src={spectacle.data.visuel}
            alt={spectacle.data.title}
            width={800}
            height={600}
            class="absolute inset-0 w-full h-full object-cover object-top"
            loading="eager"
            fetchpriority="high"
          />
        </div>

        <div class="md:w-1/2 p-8 md:p-12 flex flex-col justify-center">
          <p class="text-primary font-bold text-bodyBig">
            {spectacle.data.creation}
          </p>
          <h1 class="text-h2 md:text-heading1 text-white font-display--headings pb-4 leading-tight">
            {spectacle.data.title}
          </h1>

          <div class="flex flex-wrap gap-4 pb-4">
            <div class="flex items-center gap-2 text-accentWarning">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span class="text-white text-bodyMedium font-medium">
                {spectacle.data.duree}
              </span>
            </div>
            <div class="flex items-center gap-2 text-accentWarning">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                ></path>
              </svg>
              <span class="text-white text-bodyMedium font-medium">
                {spectacle.data.public}
              </span>
            </div>
          </div>
        </div>
      </article>

      <!-- <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 text-dark">
        <div class="lg:col-span-2 prose prose-lg max-w-none">
          <p class="font-bold text-secondary">
            Vous cherchez désespérément les moyens de boucler vos fins de mois
            ou encore vous désirez changer de yatch ?
          </p>
          <p>
            Cette conférence est faite pour vous, chômeureuses, mais aussi pour
            vos ami.e.s riches. Grâce à René et Marcelle, travailleureuses
            sociales de terrain, expert.e.s de la finance facile, vous en
            apprendrez autant sur vous mêmes que sur votre compte en banque.
          </p>
          <p>
            <strong>Comment devenir riche</strong> est une vrai fausse conférence
            sur les thèmes de l'argent, du développement personnel, des classes sociales,
            de la vulgarisation économique et des questions de société.
          </p>
          <blockquote
            class="bg-white p-6 rounded-r-lg border-l-4 border-accentWarning italic"
          >
            « L'argent n'est qu'une fiction. » — Aristote
          </blockquote>
        </div> -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16 pb-16">
        <div
          class="lg:col-span-2 py-10 text-body prose prose-invert max-w-none
            prose-blockquote:border-l-4 prose-blockquote:border-accentWarning
            prose-blockquote:pl-6
            prose-blockquote:text-primary prose-blockquote:text-lg
            prose-blockquote:not-italic"
        >
          <Content />
        </div>

        <aside
          class="bg-dark/80 border border-white/10 text-white p-8 shadow-sm h-fit space-y-8"
        >
          <div>
            <h4
              class="font-display--headings uppercase tracking-wider text-secondary mb-4 border-b pb-2"
            >
              Distribution
            </h4>
            <div class="space-y-4">
              <div>
                <p class="text-xs uppercase tracking-wider text-white/60">Écriture et jeu</p>
                <p class="font-medium text-white">
                  {spectacle.data.writeAndGame}
                </p>
              </div>
              <div>
                <p class="text-xs uppercase tracking-wider text-white/60">
                  {spectacle.data.otherPartRole}
                </p>
                <p class="font-medium text-white">{spectacle.data.otherPart}</p>
              </div>
            </div>
          </div>

          <div>
            <h4
              class="font-display--headings uppercase tracking-wider text-secondary mb-4 border-b pb-2"
            >
              Infos Terrain
            </h4>
            <div class="space-y-4">
              <div>
                <p class="text-xs uppercase tracking-wider text-white/60">Espace</p>
                <p class="font-medium text-white">{spectacle.data.espace}</p>
              </div>
              <p class="text-body text-white/60">
                {spectacle.data.espaceDetail}
              </p>
            </div>
          </div>
          <div>
            <h4
              class="font-display--headings uppercase tracking-wider text-secondary mb-4 border-b pb-2"
            >
              Soutien à la création
            </h4>
            <div class="space-y-4">
              <div>
                <p class="text-xs uppercase tracking-wider text-white/60">Support</p>
                <p class="font-medium text-white">{spectacle.data.support}</p>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>
</PageLayout>
