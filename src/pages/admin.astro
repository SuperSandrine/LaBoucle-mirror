---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';

if (import.meta.env.PROD) {
  throw new Error('Keystatic admin UI desactivee en production');
}
---

<BaseLayout title="Admin - La Boucle de la Boucle">
  <main class="min-h-screen bg-dark text-white flex items-center justify-center px-6 py-24">
    <div class="max-w-xl text-center flex flex-col gap-6">
      <p class="font-display--headings text-primary uppercase tracking-widest">Administration</p>
      <h1 class="font-display--bigHeading text-h2 text-shine">Ouverture de l'interface d'edition</h1>
      <p class="text-body text-lightGrey/80 leading-relaxed">
        Vous allez etre redirige vers l'espace Keystatic pour gerer les spectacles, les dates et les stages.
      </p>
      <p class="text-sm text-lightGrey/60">
        Si rien ne se passe, utilisez ce lien :
        <a class="text-primary underline underline-offset-4 ml-1" href="/keystatic">ouvrir Keystatic</a>
      </p>
    </div>
  </main>
</BaseLayout>

<script>
  window.location.replace('/keystatic');
</script>
