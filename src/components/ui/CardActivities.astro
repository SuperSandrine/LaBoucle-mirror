---
// src/components/ui/CardActivite.astro
// Composant générique pour spectacles ET stages
// Props communes, rendu identique au ShowCard original
import { Image } from 'astro:assets';

interface Props {
  item: {
    slug: string;
    data: {
      title: string;
      synopsis: string;
      duree: string;
      public: string;
      visuel: string;
      // Champs optionnels selon le type
      genreEtRegistre?: string;
      typeActivite?: string; // "stage" | "atelier" | "spectacle"
      tarif?: string;
      format?: string;
    };
  };
  index: number;
  anchorMode?: boolean;
  baseUrl?: string; // "/spectacles" ou "/stages"
  ctaLabel?: string; // "Découvrir le spectacle" ou "En savoir plus"
}

const { item, index, anchorMode, baseUrl, ctaLabel } = Astro.props;

const {
  title,
  synopsis,
  duree,
  public: publicValue,
  visuel,
  typeActivite,
} = item.data;

//console.log(item.data.typeActivite);

const href = anchorMode ? `#${item.slug}` : `${baseUrl}/${item.slug}`;

// Alternance gauche/droite effet en "Z"
const isEven = index % 2 === 0;

// Badge couleur selon le type
const badgeColor =
  typeActivite === "stage"
    ? "badge-secondary-solid"
    : typeActivite === "atelier"
      ? "badge-primary-solid"
      : "badge-primary-solid";

const badgeLabel =
  typeActivite === "stage"
    ? "Stage"
    : typeActivite === "atelier"
      ? "Atelier mensuel"
      : (item.data.genreEtRegistre ?? "");
---

<article
  class={`flex flex-col ${isEven ? "md:flex-row md:rotate-1" : "md:flex-row-reverse md:-rotate-1"} bg-secondary/10 border border-secondary/20 overflow-hidden mb-8 w-4/5 mx-auto min-h-100 shadow-card`}
>
  <!-- Image -->
  <div class="md:w-1/2 relative min-h-75 md:min-h-full">
    <Image
      src={visuel}
      alt={title}
      width={800}
      height={600}
      class="absolute inset-0 w-full h-full object-cover object-top"
      loading="lazy"
    />
    <!-- Badge type -->
    {
      badgeLabel && (
        <span
          class={`absolute top-4 left-4 ${badgeColor}`}
        >
          {badgeLabel}
        </span>
      )
    }
  </div>

  <!-- Contenu -->
  <div class="md:w-1/2 px-12 py-20 flex flex-col justify-center">
    <h2 class="text-h3 text-white font-display--headings mb-4">
      {title}
    </h2>

    <!-- Méta : durée + public -->
    <div class="flex flex-wrap items-center gap-x-6 gap-1 pb-6">
      <!-- Durée -->
      <span class="flex items-center gap-1 text-accentWarning font-bold">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="text-white/80 text-xl font-normal">{duree}</p>
      </span>

      <!-- Public -->
      <span class="flex items-center gap-1 text-accentWarning font-bold">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
          ></path>
        </svg>
        <p class="text-white/80 text-xl font-normal">{publicValue}</p>
      </span>

      <!-- Tarif si présent (stages uniquement) -->
      {
        item.data.tarif && (
          <span class="flex items-center gap-1 text-accentWarning font-bold">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <p class="text-white/80 text-xl font-normal">{item.data.tarif}</p>
          </span>
        )
      }
    </div>

    <!-- Synopsis -->
    <p class="text-body text-white/70 pb-8">
      {synopsis}
    </p>

    <!-- CTA -->
    <a href={href} class="w-fit btn-outline">
      {ctaLabel}
    </a>
  </div>
</article>
