---
// src/components/ui/CardActivite.astro
// Composant générique pour spectacles ET stages
// Props communes, rendu identique au ShowCard original

interface Props {
  item: {
    slug: string;
    data: {
      title: string;
      synopsis: string;
      duree: string;
      public: string;
      visuel: string;
      // Champs optionnels selon le type
      genreEtRegistre?: string;
      typeActivite?: string; // "stage" | "atelier" | "spectacle"
      tarif?: string;
      format?: string;
    };
  };
  index: number;
  anchorMode?: boolean;
  baseUrl?: string; // "/spectacles" ou "/stages"
  ctaLabel?: string; // "Découvrir le spectacle" ou "En savoir plus"
}

const {
  item,
  index,
  anchorMode = false,
  baseUrl = "/spectacles",
  ctaLabel = "En savoir plus",
} = Astro.props;

const { title, synopsis, duree, public: publicValue, visuel, typeActivite } =
  item.data;

const href = anchorMode ? `#${item.slug}` : `${baseUrl}/${item.slug}`;

// Alternance gauche/droite effet en "Z"
const isEven = index % 2 === 0;

// Badge couleur selon le type
const badgeColor =
  typeActivite === "stage"
    ? "bg-secondary text-white"
    : typeActivite === "atelier"
      ? "bg-accent text-white"
      : "bg-primary text-dark";

const badgeLabel =
  typeActivite === "stage"
    ? "Stage"
    : typeActivite === "atelier"
      ? "Atelier mensuel"
      : item.data.genreEtRegistre ?? "";
---

<article
  class={`flex flex-col ${isEven ? "md:flex-row" : "md:flex-row-reverse"} bg-lightGrey overflow-hidden shadow-lg mb-8 w-4/5 mx-auto min-h-[400px]`}
>
  <!-- Image -->
  <div class="md:w-1/2 relative min-h-[300px] md:min-h-full">
    <img
      src={visuel}
      alt={title}
      class="absolute inset-0 w-full h-full object-cover object-top"
    />
    <!-- Badge type -->
    {badgeLabel && (
      <span class={`absolute top-4 left-4 px-3 py-1 text-sm font-bold uppercase tracking-wide ${badgeColor}`}>
        {badgeLabel}
      </span>
    )}
  </div>

  <!-- Contenu -->
  <div class="md:w-1/2 p-8 py-16 flex flex-col justify-center">
    <h2 class="text-h3 text-dark font-display--headings mb-4">
      {title}
    </h2>

    <!-- Méta : durée + public -->
    <div class="flex flex-wrap items-center gap-6 pb-6">
      <!-- Durée -->
      <span class="flex items-center gap-1">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 text-accentWarning"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="text-dark text-base font-normal">{duree}</p>
      </span>

      <!-- Public -->
      <span class="flex items-center gap-1">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 text-accentWarning"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
          ></path>
        </svg>
        <p class="text-dark text-base font-normal">{publicValue}</p>
      </span>

      <!-- Tarif si présent (stages uniquement) -->
      {item.data.tarif && (
        <span class="flex items-center gap-1">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 text-accentWarning"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path>
          </svg>
          <p class="text-dark text-base font-normal">{item.data.tarif}</p>
        </span>
      )}
    </div>

    <!-- Synopsis -->
    <p class="text-base text-dark pb-8 leading-relaxed">
      {synopsis}
    </p>

    <!-- CTA -->
    <a
      href={href}
      class="w-fit border-2 border-secondary text-secondary font-display--headings px-10 py-4 text-h4 hover:bg-secondary hover:text-white transition"
    >
      {ctaLabel}
    </a>
  </div>
</article>