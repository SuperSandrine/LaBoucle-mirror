---
//TODO: nettoyer code
//DONE: rendre dynamique les dates
//TODO: afficher 3 dates maximums, à partir de la date d'aujourd'hui; les 3 dates à venir les plus proches.
// DONE: rendre dynamique le choix des spectacles dans la collection keystatic pour que le choix soit définit entre les spectacle disponibles.
// DONE: doit aussi afficher les dates de stages (est-ce que c'est une collection avec le choix du stage ou du spectacle ou  est-ce 2 collections différentes ?)

// src/components/sections/Dates.astro

import { getCollection } from "astro:content";

// Récupère toutes les dates
const datesCollection = await getCollection("dates");

// Console log pour debug
//console.log("=== DATES DEBUG ===");
//console.log("Nombre de dates:", datesCollection.length);
//console.log("Dates:", datesCollection);
//console.log("Première date:", datesCollection[0]?.data);

// Trie par date (optionnel)
const sortedDates = datesCollection.sort(
  (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime(),
);

// Trie par date et filtre pour n'afficher que les 3 prochaines dates à partir d'aujourd'hui
const today = new Date();
const nextDates = sortedDates
  .filter((event) => new Date(event.data.date) >= today)
  .slice(0, 3);

//récupère et formate les données pour l'affichage
const getEventTitle = (event: (typeof sortedDates)[number]) => {
  return (
    event.data.evenement?.value ??
    (event.data as { titre?: string }).titre ??
    ""
  );
};
const formatTitle = (slug: string) =>
  slug.replace(/-/g, " ").replace(/^\w/, (c) => c.toUpperCase());

const getEventType = (event: (typeof sortedDates)[number]) => {
  return (
    event.data.evenement?.discriminant ??
    (event.data as { type?: string }).type ??
    ""
  );
};

const formatDayMonth = (date: Date) =>
  date.toLocaleDateString("fr-FR", {
    day: "numeric",
    month: "long",
  });

const getEventDateDisplay = (event: (typeof sortedDates)[number]) => {
  const startDate = event.data.date;
  const endDate = event.data.dateFin;

  if (!endDate || endDate.getTime() <= startDate.getTime()) {
    return {
      main: formatDayMonth(startDate),
      year: startDate.toLocaleDateString("fr-FR", { year: "numeric" }),
    };
  }

  const startYear = startDate.getFullYear();
  const endYear = endDate.getFullYear();

  if (startYear === endYear) {
    return {
      main: `${formatDayMonth(startDate)} au ${formatDayMonth(endDate)}`,
      year: String(endYear),
    };
  }

  return {
    main: `${formatDayMonth(startDate)} ${startYear} au ${formatDayMonth(endDate)}`,
    year: String(endYear),
  };
};
---
<section class="bg-primary py-16 md:py-20 px-6">
  <div class="max-w-5xl mx-auto">

    <h2 class="font-display--headings text-dark text-h2 mb-4">
      Nos prochaines dates
    </h2>

    <!-- Liste desktop : tableau horizontal border-b ou pas dans la div -->
    <div class="hidden md:block">
      {nextDates.map((event) => {
        const eventDateDisplay = getEventDateDisplay(event);
        return (
          <div class="flex items-center gap-8 py-6  border-dark/20 last:border-0">
            
            <!-- Date -->
            <div class="w-44 shrink-0">
              <p class="font-bold text-bodyBig text-dark leading-snug">
                {eventDateDisplay.main}
              </p>
              <p class="text-body text-dark/70">{eventDateDisplay.year}</p>
            </div>

            <!-- Lieu -->
            <div class="w-44 shrink-0">
              <p class="text-body text-dark/80">{event.data.lieu}</p>
            </div>

            <!-- Titre + type -->
            <div class="flex-grow">
              <h3 class="font-display--headings text-h3 text-dark leading-tight">
                {formatTitle(getEventTitle(event))}
              </h3>
              <p class="text-body text-dark/60 mt-1">{getEventType(event)}</p>
            </div>

            <!-- CTA -->
            <a
              href={`/spectacles/${getEventTitle(event)}`}
              class="shrink-0 border border-dark text-dark font-display--headings px-6 py-3 text-body
                     hover:bg-dark hover:text-primary transition-all duration-300 whitespace-nowrap"
            >
              En savoir plus
            </a>
          </div>
        );
      })}
    </div>

    <!-- Liste mobile : cartes empilées -->
    <div class="flex flex-col gap-4 md:hidden">
      {nextDates.map((event) => {
        const eventDateDisplay = getEventDateDisplay(event);
        return (
          <div class="border border-dark/20 p-5 flex flex-col gap-3">

            <!-- Date + type en ligne -->
            <div class="flex items-start justify-between gap-2">
              <div>
                <p class="font-bold text-bodyBig text-dark leading-snug">
                  {eventDateDisplay.main}
                </p>
                <p class="text-body text-dark/70">{eventDateDisplay.year}</p>
              </div>
              <span class="text-xs font-bold text-dark/50 uppercase tracking-widest pt-1">
                {getEventType(event)}
              </span>
            </div>

            <!-- Séparateur -->
            <div class="border-t border-dark/15"></div>

            <!-- Titre -->
            <h3 class="font-display--headings text-h3 text-dark leading-tight">
              {formatTitle(getEventTitle(event))}
            </h3>

            <!-- Lieu -->
            <p class="text-body text-dark/70">{event.data.lieu}</p>

            <!-- CTA pleine largeur -->
            <a
              href={`/spectacles/${getEventTitle(event)}`}
              class="mt-1 text-center border border-dark text-dark font-display--headings px-6 py-3 text-body
                     hover:bg-dark hover:text-primary transition-all duration-300"
            >
              En savoir plus
            </a>
          </div>
        );
      })}
    </div>

    <!-- Lien calendrier complet -->
    <!-- <div class="flex justify-center mt-10">
      <a
        href="/calendrier"
        class="bg-dark text-white font-display--headings px-10 py-4 text-h4
               hover:text-primary transition-colors duration-300"
      >
        Toutes les dates →
      </a>
    </div> -->

  </div>
</section>

