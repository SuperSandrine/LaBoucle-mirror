---
// TODO: revoir les md des spectacles et faire des vrais spectacles
import ShowCard from "../ui/ShowCard.astro";

// Simulation des données provenant de sortedShow
import { getCollection } from "astro:content";
const spectaclesCollection = await getCollection("spectacles");
const datesCollection = await getCollection("dates");
const { anchorMode = false } = Astro.props;

const findFirstDate = (slug: string) => {
  const datesForShow = datesCollection
    .filter((item) => item.data.evenement?.discriminant === "spectacle")
    .filter((item) => item.data.evenement?.value === slug)
    .map((item) => item.data.date)
    .sort((a, b) => a.getTime() - b.getTime());
  return datesForShow.length > 0 ? datesForShow[0] : undefined;
};

const sortedSpectaclesCollection = [...spectaclesCollection].sort((a, b) => {
  const dateA = findFirstDate(a.slug);
  const dateB = findFirstDate(b.slug);
  if (!dateA && !dateB) return 0;
  if (!dateA) return 1;
  if (!dateB) return -1;
  return dateA.getTime() - dateB.getTime();
});

// Console log pour debug
//console.log('=== spectacle DEBUG ===');
//console.log('Nombre de dates:', spectaclesCollection.length);
//console.log('Dates:', spectaclesCollection);
---

<section class="bg-dark p-4 md:p-10">
  <div class="max-w-[1440px] mx-auto">
    <!-- <h2
      class="text-center text-h2 font-bold text-white text-shine p-10 font-display--headings"
    > -->
    <h2 class="font-display--headings text-white text-shine text-h2 pb-6 pl-2 md:pb-12 md:pl-8">
      Répertoire :
    </h2>

    <div class="flex flex-col items-center gap-6">
      {
        sortedSpectaclesCollection.map((event, index) => (
          <ShowCard event={event} index={index} anchorMode={anchorMode} />
        ))
      }
    </div>
  </div>
</section>
