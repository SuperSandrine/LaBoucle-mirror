---
import { getCollection } from "astro:content";
import { formatDayMonth, getEventTitle, getEventType } from "../../utils/dates";

type EventFilter = "all" | "spectacle" | "stage";

const { filter } = Astro.props as { filter?: EventFilter };
const pathname = Astro.url.pathname;

console.log("pathname", pathname);

const inferredFilter: EventFilter = pathname.startsWith("/stages")
  ? "stage"
  : pathname.startsWith("/spectacles")
    ? "spectacle"
    : "all";

const activeFilter: EventFilter = filter ?? inferredFilter;

const datesCollection = await getCollection("dates");

const sortedDates = datesCollection.sort(
  (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime(),
);

const today = new Date();
today.setHours(0, 0, 0, 0);

// getEventType moved to src/utils/dates.ts

const filteredDates = sortedDates.filter((event) => {
  if (activeFilter === "all") return true;
  return getEventType(event).toLowerCase() === activeFilter;
});

const upcomingDates = filteredDates
  .filter((event) => new Date(event.data.date) >= today)
  .sort(
    (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime(),
  );

const pastDates = filteredDates
  .filter((event) => new Date(event.data.date) < today)
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );

const formatTitle = (slug: string) =>
  slug.replace(/-/g, " ").replace(/^\w/, (c) => c.toUpperCase());

const getEventDateDisplay = (event: (typeof sortedDates)[number]) => {
  const startDate = event.data.date;
  const endDate = event.data.dateFin;

  if (!endDate || endDate.getTime() <= startDate.getTime()) {
    return {
      main: formatDayMonth(startDate),
      year: startDate.toLocaleDateString("fr-FR", { year: "numeric" }),
    };
  }

  const startYear = startDate.getFullYear();
  const endYear = endDate.getFullYear();

  if (startYear === endYear) {
    return {
      main: `${formatDayMonth(startDate)} au ${formatDayMonth(endDate)}`,
      year: String(endYear),
    };
  }

  return {
    main: `${formatDayMonth(startDate)} ${startYear} au ${formatDayMonth(endDate)}`,
    year: String(endYear),
  };
};
---

<section class="bg-primary py-16 md:py-20 px-6">
  <div class="max-w-5xl mx-auto">

    <h2 class="font-display--headings text-dark text-h2 mb-4">
      Nos dates
    </h2>

    <!-- Liste desktop -->
    <div class="hidden md:block">

      {upcomingDates.map((event) => {
        const eventDateDisplay = getEventDateDisplay(event);
        return (
          <div class="flex items-center gap-8 py-6 border-b border-dark/20 last:border-0">
            <div class="w-44 shrink-0">
              <p class="font-bold text-bodyBig text-dark leading-snug">{eventDateDisplay.main}</p>
              <p class="text-body text-dark/70">{eventDateDisplay.year}</p>
            </div>
            <div class="w-44 shrink-0">
              <p class="text-body text-dark/80">{event.data.lieu}</p>
            </div>
            <div class="flex-grow">
              <h3 class="font-display--headings text-h3 text-dark leading-tight">
                {formatTitle(getEventTitle(event))}
              </h3>
              <p class="text-body text-dark/60">{getEventType(event)}</p>
            </div>
            <a
              href={getEventType(event) === "spectacle" ? `/spectacles/${getEventTitle(event)}` : `/stages#${getEventTitle(event)}`}
              class="shrink-0 btn-outlineDark whitespace-nowrap"
            >
              En savoir plus
            </a>
          </div>
        );
      })}

      {pastDates.length > 0 && (
        <div class="flex items-center gap-4 py-4">
          <div class="flex-1 border-t border-dark/30" />
          <span class="font-display--headings text-dark/50 text-sm uppercase tracking-widest">
            Dates passées
          </span>
          <div class="flex-1 border-t border-dark/30" />
        </div>
      )}

      {pastDates.map((event) => {
        const eventDateDisplay = getEventDateDisplay(event);
        return (
          <div class="flex items-center gap-8 py-6 border-b border-dark/20 last:border-0 opacity-60">
            <div class="w-44 shrink-0">
              <p class="font-bold text-bodyBig text-dark leading-snug">{eventDateDisplay.main}</p>
              <p class="text-body text-dark/70">{eventDateDisplay.year}</p>
            </div>
            <div class="w-44 shrink-0">
              <p class="text-body text-dark/80">{event.data.lieu}</p>
            </div>
            <div class="flex-grow">
              <h3 class="font-display--headings text-h3 text-dark leading-tight">
                {formatTitle(getEventTitle(event))}
              </h3>
              <p class="text-body text-dark/60">{getEventType(event)}</p>
            </div>
          </div>
        );
      })}

    </div>

    <!-- Liste mobile : cartes empilées -->
    <div class="flex flex-col gap-4 md:hidden">

      {upcomingDates.map((event) => {
        const eventDateDisplay = getEventDateDisplay(event);
        return (
          <div class="border border-dark/20 p-5 flex flex-col gap-3">
            <div class="flex items-start justify-between gap-2">
              <div>
                <p class="font-bold text-bodyBig text-dark leading-snug">{eventDateDisplay.main}</p>
                <p class="text-body text-dark/70">{eventDateDisplay.year}</p>
              </div>
              <span class="text-xs font-bold text-dark/50 uppercase tracking-widest pt-1">
                {getEventType(event)}
              </span>
            </div>
            <div class="border-t border-dark/15"></div>
            <h3 class="font-display--headings text-h3 text-dark leading-tight">
              {formatTitle(getEventTitle(event))}
            </h3>
            <p class="text-body text-dark/70">{event.data.lieu}</p>
            <a
              href={getEventType(event) === "spectacle" ? `/spectacles/${getEventTitle(event)}` : `/stages#${getEventTitle(event)}`}
              class="mt-1 text-center btn-outlineDark w-full"
            >
              En savoir plus
            </a>
          </div>
        );
      })}

      {pastDates.length > 0 && (
        <div class="flex items-center gap-4 py-4">
          <div class="flex-1 border-t border-dark/30" />
          <span class="font-display--headings text-dark/50 text-sm uppercase tracking-widest">
            Dates passées
          </span>
          <div class="flex-1 border-t border-dark/30" />
        </div>
      )}

      {pastDates.map((event) => {
        const eventDateDisplay = getEventDateDisplay(event);
        return (
          <div class="border border-dark/20 p-5 flex flex-col gap-3 opacity-60">
            <div class="flex items-start justify-between gap-2">
              <div>
                <p class="font-bold text-bodyBig text-dark leading-snug">{eventDateDisplay.main}</p>
                <p class="text-body text-dark/70">{eventDateDisplay.year}</p>
              </div>
              <span class="text-xs font-bold text-dark/50 uppercase tracking-widest pt-1">
                {getEventType(event)}
              </span>
            </div>
            <div class="border-t border-dark/15"></div>
            <h3 class="font-display--headings text-h3 text-dark leading-tight">
              {formatTitle(getEventTitle(event))}
            </h3>
            <p class="text-body text-dark/70">{event.data.lieu}</p>
          </div>
        );
      })}

    </div>

  </div>
</section>
