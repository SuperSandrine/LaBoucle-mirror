---
// src/components/sections/Stages.astro
// Section liste des stages pour la page d'accueil
import CardActivities from "../ui/CardActivities.astro";
import { getCollection } from "astro:content";

const stagesCollection = await getCollection("stages");
const { anchorMode = false } = Astro.props;
---

<section class="bg-dark p-10">
  <div class="max-w-[1440px] mx-auto">
    <!-- <h2
    class="text-center text-h2 font-bold text-white text-shine p-10 font-display--headings"
  >
    Stages & Ateliers
  </h2> -->
    <!-- <h1 class="font-display--headings text-white text-h2 md:text-heading1 leading-none text-shine pb-20
">
  Stages & Ateliers
</h1> -->

    {!anchorMode && (
      <h2 class="font-display--headings text-white text-shine text-h2 pb-12 pl-8">
        Stages & Ateliers :
      </h2>
    )}
    <div class="flex flex-col items-center gap-6">
      {
        stagesCollection.map((item, index) => (
          <CardActivities
            item={item}
            index={index}
            anchorMode={anchorMode}
            baseUrl="/stages"
            ctaLabel={`Découvrir ${item.data.typeActivite === "stage" ? "le stage" : "l'atelier"}`}
          />
        ))
      }
    </div>
  </div>
</section>
