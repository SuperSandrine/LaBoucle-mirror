---
import CardTeam from "../ui/CardTeam.astro";
import type { ImageMetadata } from "astro";
import imageCharlotte from "../../images/charlotte.webp";
import imageLeo from "../../images/leo.webp";
import imageAnnabelle from "../../images/annabelle.webp";
import imageZicky from "../../images/ziky.webp";

interface TeamMember {
  name: string;
  role: string;
  image: ImageMetadata;
}
const team: TeamMember[] = [
  {
    name: "Leo Sciarrino",
    role: "Co-directeur artistique, clown",
    image: imageLeo,
  },
  {
    name: "Annabelle Vaillant",
    role: "Co-directrice artistique, clown",
    image: imageAnnabelle,
  },
  {
    name: "Ziky Versari",
    role: "Clown",
    image: imageZicky,
  },
  {
    name: "Charlotte Weidmann",
    role: `Directrice de production du festival "Les Désinvoltes"`,
    image: imageCharlotte, // On passe directement l'import, pas de accolades !
  },
];
---

<section class="p-10 bg-dark">
  <div class="max-w-[1440px] mx-auto">
    <h2 class="font-display--headings text-white text-shine text-h2 pb-12 pl-8">
      Nous sommes :
    </h2>
    <div class="flex flex-wrap justify-center">
      {team.map((member, index) => <CardTeam {...member} index={index} />)}
    </div>
  </div>
</section>
