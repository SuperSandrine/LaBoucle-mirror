---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
}

const {
  title = "La Boucle de la boucle",
  description = "La Boucle de la boucle — compagnie de théâtre et clown. Spectacles tout terrain, stages et ateliers en Creuse et partout en France.",
  ogImage = "/images/logo.svg",
  ogType = "website",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/images/logo.svg" />
    <link
      rel="preload"
      href="/fonts/Children-of-the-revolution.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/TrashHand.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO de base -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph (réseaux sociaux + aperçus IA) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="La Boucle de la boucle" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Données structurées — compagnie -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["PerformingGroup", "Organization"],
      "name": "La Boucle de la Boucle",
      "url": "https://laboucledelaboucle.fr",
      "email": "laboucledelaboucle@gmail.com",
      "description": "Compagnie de clown et théâtre de rue créée en Creuse en 2021. Spectacles tout terrain, stages et ateliers, festival Les Désinvoltes.",
      "foundingDate": "2021",
      "areaServed": "France",
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "Creuse",
        "addressCountry": "FR"
      },
      "sameAs": ["https://www.instagram.com/laboucledelaboucle/"],
      "member": [
        { "@type": "Person", "name": "Leo Sciarrino", "jobTitle": "Co-directeur artistique" },
        { "@type": "Person", "name": "Annabelle Vaillant", "jobTitle": "Co-directrice artistique" },
        { "@type": "Person", "name": "Ziky Versari", "jobTitle": "Clown" },
        { "@type": "Person", "name": "Charlotte Weidmann", "jobTitle": "Directrice de production" }
      ]
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
